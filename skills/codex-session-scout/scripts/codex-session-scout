#!/usr/bin/env python3
"""Inspect local Codex session history, live activity, and event streams."""

from __future__ import annotations

import argparse
import gzip
import json
import os
import re
import shutil
import subprocess
import sys
import time
from collections import deque
from contextlib import contextmanager
from datetime import datetime, timezone
from pathlib import Path

__version__ = "2.3.0"

DEFAULT_SESSIONS_DIR = "/root/.codex/sessions"
DEFAULT_ARCHIVED_DIR = "/root/.codex/archived_sessions"
SESSION_INDEX_FILE = "session_index.jsonl"

UUID_RE = re.compile(
    r"[0-9a-fA-F]{8}-"
    r"[0-9a-fA-F]{4}-"
    r"[0-9a-fA-F]{4}-"
    r"[0-9a-fA-F]{4}-"
    r"[0-9a-fA-F]{12}"
)
DURATION_RE = re.compile(r"^(?P<value>\d+)(?P<unit>[smhd])$")

VALID_COLUMNS = ("live", "age", "status", "id", "cwd", "repo", "path", "title")
VIEW_COLUMNS = {
    "summary": ("age", "title"),
    "ops": ("live", "age", "status", "id", "cwd", "title"),
    "paths": ("live", "age", "status", "id", "cwd", "repo", "path", "title"),
}
STATUS_ORDER = {"running": 0, "completed": 1, "stale": 2}
SOURCE_CHOICES = ("live", "all")
STATUS_CHOICES = tuple(STATUS_ORDER.keys())
DURATION_UNITS = {"s": 1, "m": 60, "h": 3600, "d": 86400}


@contextmanager
def open_session_text(path: Path):
    """Open a Codex session file as a text stream."""

    name = path.name
    if name.endswith(".jsonl.gz"):
        f = gzip.open(path, "rt", encoding="utf-8", errors="replace")
        try:
            yield f
        finally:
            f.close()
        return

    if name.endswith(".jsonl.zst"):
        proc = subprocess.Popen(
            ["zstd", "-dc", str(path)],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            encoding="utf-8",
            errors="replace",
        )
        try:
            assert proc.stdout is not None
            yield proc.stdout
        finally:
            try:
                if proc.stdout:
                    proc.stdout.close()
            finally:
                try:
                    proc.terminate()
                except Exception:
                    pass
                try:
                    proc.wait(timeout=1)
                except Exception:
                    pass
        return

    with path.open("r", encoding="utf-8", errors="replace") as f:
        yield f


def parse_iso(value: str) -> datetime | None:
    if not value:
        return None
    try:
        return datetime.fromisoformat(value.replace("Z", "+00:00"))
    except Exception:
        return None


def parse_duration(value: str) -> int:
    match = DURATION_RE.fullmatch(value.strip().lower())
    if not match:
        raise argparse.ArgumentTypeError(
            f"Invalid duration {value!r}. Use Ns, Nm, Nh, or Nd."
        )
    return int(match.group("value")) * DURATION_UNITS[match.group("unit")]


def parse_columns(value: str) -> tuple[str, ...]:
    columns = []
    for raw in value.split(","):
        column = raw.strip().lower()
        if not column:
            continue
        if column not in VALID_COLUMNS:
            allowed = ", ".join(VALID_COLUMNS)
            raise argparse.ArgumentTypeError(
                f"Invalid column {column!r}. Allowed columns: {allowed}."
            )
        if column not in columns:
            columns.append(column)
    if not columns:
        raise argparse.ArgumentTypeError("At least one column is required.")
    return tuple(columns)


def extract_id_from_filename(name: str) -> str:
    match = UUID_RE.search(name)
    if not match:
        return ""
    return match.group(0)


def extract_title_from_message(message: str) -> str:
    lines = [line.strip() for line in message.splitlines()]
    for index, line in enumerate(lines):
        if "My request for Codex" in line:
            for candidate in lines[index + 1 :]:
                if candidate:
                    return candidate
            return ""
    for line in lines:
        if line and not line.startswith("#"):
            return line
    return ""


def looks_like_local_path(value: object) -> bool:
    if not isinstance(value, str):
        return False
    value = value.strip()
    return value.startswith("/") and len(value) > 1


def find_path_hint(node: object) -> str:
    if isinstance(node, dict):
        for key in ("cwd", "workdir", "workspace", "project_path", "root_path"):
            value = node.get(key)
            if looks_like_local_path(value):
                return str(value).strip()
        for key, value in node.items():
            key_norm = str(key).casefold()
            if any(token in key_norm for token in ("cwd", "workdir", "workspace", "project", "root")) and looks_like_local_path(value):
                return str(value).strip()
        for value in node.values():
            found = find_path_hint(value)
            if found:
                return found
    elif isinstance(node, list):
        for value in node:
            found = find_path_hint(value)
            if found:
                return found
    return ""


def derive_repo_hint(cwd: str, git_meta: object) -> str:
    if isinstance(git_meta, dict):
        repo_url = str(git_meta.get("repository_url") or "").strip()
        if repo_url:
            return repo_url
    if cwd:
        current = Path(cwd)
        for candidate in (current, *current.parents):
            if (candidate / ".git").exists():
                return str(candidate)
    return ""


def format_age(ts: datetime, now: datetime) -> str:
    seconds = max(0, int((now - ts).total_seconds()))
    if seconds < 60:
        return f"{seconds}s"
    if seconds < 3600:
        return f"{seconds // 60}m"
    if seconds < 86400:
        return f"{seconds // 3600}h"
    return f"{seconds // 86400}d"


def truncate(text: str, max_len: int) -> str:
    if max_len <= 0 or len(text) <= max_len:
        return text
    return text[: max_len - 1].rstrip() + "…"


def build_source_roots(source: str) -> list[tuple[str, Path]]:
    roots = [("live", Path(DEFAULT_SESSIONS_DIR))]
    if source == "all":
        roots.append(("archived", Path(DEFAULT_ARCHIVED_DIR)))
    return roots


def load_session_index_entries(source_roots: list[tuple[str, Path]]) -> dict[str, dict[str, str]]:
    entries: dict[str, dict[str, str]] = {}
    codex_homes = {str(root.resolve().parent) for _, root in source_roots}
    for codex_home in codex_homes:
        index_path = Path(codex_home) / SESSION_INDEX_FILE
        if not index_path.exists():
            continue
        try:
            with index_path.open("r", encoding="utf-8", errors="replace") as f:
                for line in f:
                    try:
                        obj = json.loads(line)
                    except Exception:
                        continue
                    thread_id = str(obj.get("id") or "").strip()
                    if not thread_id:
                        continue
                    entries[thread_id] = {
                        "thread_name": str(obj.get("thread_name") or "").strip(),
                        "updated_at": str(obj.get("updated_at") or "").strip(),
                    }
        except OSError:
            continue
    return entries


def iter_session_paths(source_roots: list[tuple[str, Path]]):
    patterns = ("*.jsonl", "*.jsonl.gz", "*.jsonl.zst")
    for source_name, root in source_roots:
        if not root.exists():
            continue
        for pattern in patterns:
            for path in root.rglob(pattern):
                if path.is_file():
                    yield source_name, path


def read_last_json_line(path: Path) -> str | None:
    if path.name.endswith(".jsonl"):
        try:
            with path.open("rb") as f:
                f.seek(0, os.SEEK_END)
                end = f.tell()
                if end <= 0:
                    return None

                pos = end - 1
                while pos >= 0:
                    f.seek(pos)
                    if f.read(1) not in {b"\n", b"\r"}:
                        break
                    pos -= 1

                if pos < 0:
                    return None

                start = pos
                while start >= 0:
                    f.seek(start)
                    if f.read(1) == b"\n":
                        start += 1
                        break
                    start -= 1

                if start < 0:
                    start = 0

                f.seek(start)
                raw = f.read(pos - start + 1)
        except OSError:
            return None
        return raw.decode("utf-8", errors="replace").strip() or None

    tail = deque(maxlen=1)
    try:
        with open_session_text(path) as f:
            for line in f:
                line = line.strip()
                if line:
                    tail.append(line)
    except OSError:
        return None
    return tail[0] if tail else None


def tail_session_event(path: Path) -> tuple[datetime | None, bool]:
    raw = read_last_json_line(path)
    if not raw:
        return None, False
    try:
        obj = json.loads(raw)
    except Exception:
        return None, False
    payload = obj.get("payload") or {}
    last_ts = parse_iso(obj.get("timestamp") or "")
    completed = obj.get("type") == "event_msg" and payload.get("type") == "task_complete"
    return last_ts, completed


def session_info(
    path: Path,
    source_name: str,
    index_entries: dict[str, dict[str, str]] | None = None,
) -> dict:
    started_at = None
    session_id = ""
    preview = ""
    cwd = ""
    repo = ""
    try:
        with open_session_text(path) as f:
            for line in f:
                try:
                    obj = json.loads(line)
                except Exception:
                    continue
                payload = obj.get("payload") or {}
                if obj.get("type") == "session_meta":
                    if not session_id:
                        session_id = (
                            payload.get("id")
                            or payload.get("session_id")
                            or payload.get("sessionId")
                            or ""
                        )
                    if not started_at:
                        started_at = parse_iso(payload.get("timestamp") or obj.get("timestamp") or "")
                    if not cwd:
                        cwd = find_path_hint(payload)
                    if not repo:
                        repo = derive_repo_hint(cwd, payload.get("git"))
                elif obj.get("type") == "event_msg":
                    if payload.get("type") == "user_message" and not preview:
                        preview = extract_title_from_message(payload.get("message") or "")
                    if not cwd:
                        cwd = find_path_hint(payload)
                    if not repo:
                        repo = derive_repo_hint(cwd, payload.get("git"))
                if started_at and session_id and preview and cwd and repo:
                    break
    except Exception:
        pass

    last_activity_at = datetime.fromtimestamp(path.stat().st_mtime, tz=timezone.utc)
    if not session_id:
        session_id = extract_id_from_filename(path.name)
    index_entry = (index_entries or {}).get(session_id, {})
    index_updated_at = parse_iso(index_entry.get("updated_at") or "") if index_entry else None
    if path.stat().st_size == 0 and index_updated_at is not None:
        last_activity_at = index_updated_at
    if not started_at:
        started_at = index_updated_at or last_activity_at
    thread_name = str(index_entry.get("thread_name") or "")
    title = thread_name or preview or "(untitled session)"
    recovery_kind = ""
    if path.stat().st_size == 0:
        recovery_kind = "zero_byte"
    elif thread_name and not preview and not cwd and not repo:
        recovery_kind = "metadata_empty"
    return {
        "id": session_id,
        "title": title,
        "thread_name": thread_name,
        "preview": preview,
        "cwd": cwd,
        "repo": repo,
        "source": source_name,
        "path": path,
        "started_at": started_at,
        "last_activity_at": last_activity_at,
        "completed": False,
        "status": "stale",
        "age": "",
        "live_age": "",
        "recovery_kind": recovery_kind,
    }


def matches_query(
    record: dict,
    query: str | None,
    regexes: list[re.Pattern[str]],
    cwd_query: str | None,
    cwd_regexes: list[re.Pattern[str]],
    repo_query: str | None,
    repo_regexes: list[re.Pattern[str]],
) -> bool:
    haystacks = (
        record.get("title") or "",
        record.get("thread_name") or "",
        record.get("preview") or "",
        record.get("id") or "",
    )
    cwd_value = record.get("cwd") or ""
    repo_value = record.get("repo") or ""
    if query:
        query_norm = query.casefold()
        if not any(text and query_norm in text.casefold() for text in haystacks):
            return False
    if regexes:
        if not any(text and any(pattern.search(text) for pattern in regexes) for text in haystacks):
            return False
    if cwd_query and cwd_query.casefold() not in cwd_value.casefold():
        return False
    if cwd_regexes and not any(pattern.search(cwd_value) for pattern in cwd_regexes):
        return False
    if repo_query and repo_query.casefold() not in repo_value.casefold():
        return False
    if repo_regexes and not any(pattern.search(repo_value) for pattern in repo_regexes):
        return False
    return True


def index_entry_matches(
    session_id: str,
    entry: dict[str, str],
    query: str | None,
    regexes: list[re.Pattern[str]],
) -> bool:
    haystacks = (session_id, str(entry.get("thread_name") or ""))
    if query:
        query_norm = query.casefold()
        if not any(text and query_norm in text.casefold() for text in haystacks):
            return False
    if regexes:
        if not any(text and any(pattern.search(text) for pattern in regexes) for text in haystacks):
            return False
    return True


def build_index_only_record(session_id: str, entry: dict[str, str]) -> dict | None:
    updated_at = parse_iso(entry.get("updated_at") or "")
    if updated_at is None:
        return None
    return {
        "id": session_id,
        "title": str(entry.get("thread_name") or "") or "(untitled session)",
        "thread_name": str(entry.get("thread_name") or ""),
        "preview": "",
        "cwd": "",
        "repo": "",
        "source": "index",
        "path": None,
        "started_at": updated_at,
        "last_activity_at": updated_at,
        "completed": False,
        "status": "stale",
        "age": "",
        "live_age": "",
        "recovery_kind": "index_only",
    }


def session_text_matches(
    path: Path,
    fulltext_query: str | None,
    fulltext_regexes: list[re.Pattern[str]],
) -> bool:
    if not fulltext_query and not fulltext_regexes:
        return True

    query_norm = fulltext_query.casefold() if fulltext_query else None
    query_hit = query_norm is None
    regex_hit = not fulltext_regexes

    try:
        with open_session_text(path) as f:
            for line in f:
                if not query_hit and query_norm and query_norm in line.casefold():
                    query_hit = True
                if not regex_hit and any(pattern.search(line) for pattern in fulltext_regexes):
                    regex_hit = True
                if query_hit and regex_hit:
                    return True
    except OSError:
        return False
    return False


def rg_file_matches(
    source_roots: list[tuple[str, Path]],
    fulltext_query: str | None,
    fulltext_regexes: list[re.Pattern[str]],
) -> set[Path] | None:
    if not fulltext_query and not fulltext_regexes:
        return None
    if shutil.which("rg") is None:
        return None

    roots = [str(root) for _, root in source_roots if root.exists()]
    if not roots:
        return set()

    def run_rg(args: list[str]) -> set[Path] | None:
        try:
            proc = subprocess.run(
                args,
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                text=True,
                check=False,
            )
        except OSError:
            return None
        # rg exit code: 0 match, 1 no match, 2 error
        if proc.returncode not in {0, 1}:
            return None
        lines = [line.strip() for line in proc.stdout.splitlines() if line.strip()]
        return {Path(line).resolve() for line in lines}

    matched: set[Path] | None = None
    if fulltext_query:
        query_args = [
            "rg",
            "-l",
            "-i",
            "--fixed-strings",
            "--search-zip",
            fulltext_query,
            *roots,
        ]
        query_set = run_rg(query_args)
        if query_set is None:
            return None
        matched = query_set

    if fulltext_regexes:
        regex_args = ["rg", "-l", "-i", "--search-zip"]
        for pattern in fulltext_regexes:
            regex_args.extend(["-e", pattern.pattern])
        regex_args.extend(roots)
        regex_set = run_rg(regex_args)
        if regex_set is None:
            return None
        matched = regex_set if matched is None else matched.intersection(regex_set)

    return matched if matched is not None else set()


def session_status(record: dict, now: datetime, running_window_seconds: int) -> str:
    if record["completed"]:
        return "completed"
    if (now - record["last_activity_at"]).total_seconds() <= running_window_seconds:
        return "running"
    return "stale"


def collect_sessions(
    source: str,
    include_untitled: bool,
    query: str | None,
    regexes: list[re.Pattern[str]],
    cwd_query: str | None,
    cwd_regexes: list[re.Pattern[str]],
    repo_query: str | None,
    repo_regexes: list[re.Pattern[str]],
    fulltext_query: str | None,
    fulltext_regexes: list[re.Pattern[str]],
    now: datetime,
    running_window_seconds: int,
    status_filter: set[str] | None = None,
    active_within_seconds: int | None = None,
) -> list[dict]:
    source_roots = build_source_roots(source)
    index_entries = load_session_index_entries(source_roots)
    rg_matches = rg_file_matches(source_roots, fulltext_query, fulltext_regexes)
    indexed_candidate_ids: set[str] | None = None
    query_rg_matches: set[Path] | None = None
    if (query or regexes) and not any((cwd_query, cwd_regexes, repo_query, repo_regexes, fulltext_query, fulltext_regexes)):
        matched_ids = {
            session_id
            for session_id, entry in index_entries.items()
            if index_entry_matches(session_id, entry, query, regexes)
        }
        if matched_ids:
            indexed_candidate_ids = matched_ids
        query_rg_matches = rg_file_matches(source_roots, query, regexes)
    records: list[dict] = []
    seen_ids: set[str] = set()
    for source_name, path in iter_session_paths(source_roots):
        session_id_from_name = extract_id_from_filename(path.name)
        if indexed_candidate_ids is not None and session_id_from_name:
            if session_id_from_name in index_entries and session_id_from_name not in indexed_candidate_ids:
                continue
            if session_id_from_name not in index_entries and query_rg_matches is not None and path.resolve() not in query_rg_matches:
                continue
        record = session_info(path, source_name, index_entries=index_entries)
        if not include_untitled and record["title"] == "(untitled session)":
            continue
        if not matches_query(record, query, regexes, cwd_query, cwd_regexes, repo_query, repo_regexes):
            continue
        if fulltext_query or fulltext_regexes:
            path_resolved = path.resolve()
            if rg_matches is not None:
                if path_resolved in rg_matches:
                    pass
                elif path.name.endswith(".jsonl.zst"):
                    if not session_text_matches(path, fulltext_query, fulltext_regexes):
                        continue
                else:
                    continue
            elif not session_text_matches(path, fulltext_query, fulltext_regexes):
                continue
        _, record["completed"] = tail_session_event(path)
        record["status"] = session_status(record, now, running_window_seconds)
        live_seconds = (now - record["last_activity_at"]).total_seconds()
        if active_within_seconds is not None and live_seconds > active_within_seconds:
            continue
        if status_filter == {"running"} and live_seconds > running_window_seconds:
            continue
        if status_filter is not None and record["status"] not in status_filter:
            continue
        record["age"] = format_age(record["started_at"], now)
        record["live_age"] = format_age(record["last_activity_at"], now)
        records.append(record)
        if record["id"]:
            seen_ids.add(record["id"])

    for session_id, entry in index_entries.items():
        if session_id in seen_ids:
            continue
        if indexed_candidate_ids is not None and session_id not in indexed_candidate_ids:
            continue
        record = build_index_only_record(session_id, entry)
        if record is None:
            continue
        if not include_untitled and record["title"] == "(untitled session)":
            continue
        if not matches_query(record, query, regexes, cwd_query, cwd_regexes, repo_query, repo_regexes):
            continue
        if fulltext_query or fulltext_regexes:
            continue
        if status_filter == {"running"}:
            continue
        if status_filter is not None and record["status"] not in status_filter:
            continue
        live_seconds = (now - record["last_activity_at"]).total_seconds()
        if active_within_seconds is not None and live_seconds > active_within_seconds:
            continue
        record["age"] = format_age(record["started_at"], now)
        record["live_age"] = format_age(record["last_activity_at"], now)
        records.append(record)
    return records


def sort_records(records: list[dict], sort_key: str) -> None:
    if sort_key == "start":
        records.sort(
            key=lambda record: (
                -(record["started_at"].timestamp()),
                -(record["last_activity_at"].timestamp()),
            )
        )
        return
    records.sort(
        key=lambda record: (
            STATUS_ORDER[record["status"]],
            -(record["last_activity_at"].timestamp()),
            -(record["started_at"].timestamp()),
        )
    )


def record_json(record: dict) -> dict:
    return {
        "id": record["id"],
        "title": record["title"],
        "thread_name": record["thread_name"],
        "preview": record["preview"],
        "cwd": record.get("cwd") or "",
        "repo": record.get("repo") or "",
        "status": record["status"],
        "source": record["source"],
        "age": record["age"],
        "live_age": record["live_age"],
        "started_at": record["started_at"].isoformat(),
        "last_activity_at": record["last_activity_at"].isoformat(),
        "path": str(record["path"]) if record.get("path") is not None else "",
        "recovery_kind": record.get("recovery_kind") or "",
    }


def render_column(record: dict, column: str, max_title: int) -> str:
    if column == "live":
        return record["live_age"]
    if column == "age":
        return record["age"]
    if column == "status":
        return record["status"]
    if column == "id":
        return record["id"] or "-"
    if column == "cwd":
        return record.get("cwd") or "-"
    if column == "repo":
        return record.get("repo") or "-"
    if column == "path":
        return str(record["path"]) if record.get("path") is not None else "-"
    if column == "title":
        return truncate(record["title"], max_title)
    raise ValueError(f"Unknown column: {column}")


def print_table(records: list[dict], columns: tuple[str, ...], max_title: int) -> None:
    rows = [[render_column(record, column, max_title) for column in columns] for record in records]
    widths = []
    for index, column in enumerate(columns):
        values = [row[index] for row in rows]
        widths.append(max((len(value) for value in values), default=0))

    right_aligned = {"live", "age"}
    for row in rows:
        formatted = []
        for index, column in enumerate(columns):
            value = row[index]
            width = widths[index]
            if column in right_aligned:
                formatted.append(value.rjust(width))
            else:
                formatted.append(value.ljust(width) if column != "title" else value)
        print("  ".join(formatted).rstrip())


def print_tsv(records: list[dict], columns: tuple[str, ...], max_title: int) -> None:
    for record in records:
        print(
            "\t".join(render_column(record, column, max_title) for column in columns)
        )


def find_session_by_id(source: str, session_id: str) -> Path | None:
    source_roots = build_source_roots(source)
    for _, path in iter_session_paths(source_roots):
        if extract_id_from_filename(path.name) == session_id:
            return path
    index_entries = load_session_index_entries(source_roots)
    for source_name, path in iter_session_paths(source_roots):
        if session_info(path, source_name, index_entries=index_entries)["id"] == session_id:
            return path
    return None


def index_only_session_by_id(source: str, session_id: str) -> dict | None:
    source_roots = build_source_roots(source)
    entry = load_session_index_entries(source_roots).get(session_id)
    if not entry:
        return None
    return build_index_only_record(session_id, entry)


def emit_recovery_payload(recovery_kind: str, session_id: str, title: str, cwd: str, repo: str, path: str) -> dict:
    warning = {
        "zero_byte": "Session file is zero-byte; showing index-backed metadata only.",
        "metadata_empty": "Session file has no usable metadata; showing recovery metadata only.",
        "index_only": "Session file is missing; showing session_index-backed metadata only.",
    }.get(recovery_kind, "Showing recovery metadata only.")
    return {
        "type": "session_recovery",
        "payload": {
            "id": session_id,
            "title": title,
            "cwd": cwd,
            "repo": repo,
            "path": path,
            "recovery_kind": recovery_kind,
            "warning": warning,
        },
    }


def fetch_session(path: Path, output_format: str, source: str = "all") -> int:
    source_roots = build_source_roots(source)
    index_entries = load_session_index_entries(source_roots)
    session_id = extract_id_from_filename(path.name)
    info = session_info(path, "live", index_entries=index_entries)
    if info.get("recovery_kind") == "zero_byte":
        fallback = emit_recovery_payload(
            "zero_byte",
            session_id,
            info.get("title") or "",
            info.get("cwd") or "",
            info.get("repo") or "",
            str(path),
        )
        if output_format == "jsonl":
            print(json.dumps(fallback, ensure_ascii=False))
            return 0
        print(json.dumps([fallback], ensure_ascii=False, indent=2))
        return 0

    if output_format == "jsonl":
        with open_session_text(path) as f:
            for line in f:
                print(line.rstrip("\n"))
        return 0

    payload: list[object] = []
    with open_session_text(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                payload.append(json.loads(line))
            except Exception:
                payload.append({"_raw": line})
    print(json.dumps(payload, ensure_ascii=False, indent=2))
    return 0


def emit_stream_line(line: str, output_format: str) -> None:
    line = line.rstrip("\n")
    if output_format == "jsonl":
        print(line, flush=True)
        return
    raw = line.strip()
    if not raw:
        return
    try:
        obj = json.loads(raw)
    except Exception:
        obj = {"_raw": raw}
    print(json.dumps(obj, ensure_ascii=False), flush=True)


def follow_session(
    path: Path,
    output_format: str,
    since_start: bool,
    poll_interval: float,
) -> int:
    if path.name.endswith(".jsonl.gz") or path.name.endswith(".jsonl.zst"):
        print(
            "Streaming follow is supported only for live .jsonl files. "
            "Use `fetch` + polling for compressed sessions.",
            file=sys.stderr,
        )
        return 2
    if poll_interval <= 0:
        print("--poll-interval must be greater than 0.", file=sys.stderr)
        return 2

    try:
        with path.open("r", encoding="utf-8", errors="replace") as f:
            if not since_start:
                f.seek(0, os.SEEK_END)
            while True:
                line = f.readline()
                if line:
                    emit_stream_line(line, output_format)
                    continue
                time.sleep(poll_interval)
    except KeyboardInterrupt:
        return 0
    except OSError as exc:
        print(f"Failed to follow session file: {exc}", file=sys.stderr)
        return 1


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="codex-session-scout",
        description="Inspect local Codex session logs and live rollout activity.",
    )
    parser.add_argument(
        "--version",
        action="version",
        version=f"%(prog)s {__version__}",
    )

    subparsers = parser.add_subparsers(dest="command", required=True)

    list_parser = subparsers.add_parser(
        "list",
        help="List sessions with explicit filtering, sorting, and column selection.",
    )
    list_parser.add_argument(
        "--source",
        choices=SOURCE_CHOICES,
        default="live",
        help="Read only live sessions or include archived sessions as well.",
    )
    list_parser.add_argument(
        "--query",
        help="Case-insensitive substring match against title, preview, or session id.",
    )
    list_parser.add_argument(
        "--regex",
        action="append",
        default=[],
        metavar="PATTERN",
        help="Case-insensitive regex match against title, preview, or session id. Repeatable.",
    )
    list_parser.add_argument(
        "--cwd",
        help="Case-insensitive substring match against session cwd/workdir metadata.",
    )
    list_parser.add_argument(
        "--cwd-regex",
        action="append",
        default=[],
        metavar="PATTERN",
        help="Case-insensitive regex match against session cwd/workdir metadata. Repeatable.",
    )
    list_parser.add_argument(
        "--repo",
        help="Case-insensitive substring match against derived repo metadata.",
    )
    list_parser.add_argument(
        "--repo-regex",
        action="append",
        default=[],
        metavar="PATTERN",
        help="Case-insensitive regex match against derived repo metadata. Repeatable.",
    )
    list_parser.add_argument(
        "--fulltext",
        help="Case-insensitive substring match against the full session event stream.",
    )
    list_parser.add_argument(
        "--fulltext-regex",
        action="append",
        default=[],
        metavar="PATTERN",
        help="Case-insensitive regex match against the full session event stream. Repeatable.",
    )
    list_parser.add_argument(
        "--status",
        action="append",
        choices=STATUS_CHOICES,
        default=[],
        help="Filter by derived status. Repeatable.",
    )
    list_parser.add_argument(
        "--active-within",
        type=parse_duration,
        metavar="DURATION",
        help="Only keep sessions with live activity within the given duration, for example 15m or 24h.",
    )
    list_parser.add_argument(
        "--running-window",
        type=parse_duration,
        default=parse_duration("5m"),
        metavar="DURATION",
        help="Duration used to classify a session as running. Default: 5m.",
    )
    list_parser.add_argument(
        "--include-untitled",
        action="store_true",
        help="Include sessions whose title could not be inferred.",
    )
    list_parser.add_argument(
        "--sort",
        choices=("live", "start"),
        default="live",
        help="Sort by live activity or start time.",
    )
    list_parser.add_argument(
        "--view",
        choices=tuple(VIEW_COLUMNS),
        default="ops",
        help="Column preset for table or TSV output.",
    )
    list_parser.add_argument(
        "--columns",
        type=parse_columns,
        metavar="COLUMN_LIST",
        help="Comma-separated column list that overrides --view.",
    )
    list_parser.add_argument(
        "--format",
        choices=("table", "tsv", "json"),
        default="table",
        help="Output format.",
    )
    list_parser.add_argument(
        "--limit",
        type=int,
        default=100,
        help="Maximum number of sessions to emit.",
    )
    list_parser.add_argument(
        "--max-title",
        type=int,
        default=96,
        help="Maximum rendered title length for table or TSV output.",
    )
    list_parser.set_defaults(func=run_list)

    fetch_parser = subparsers.add_parser(
        "fetch",
        help="Emit the raw event stream for a single session id.",
    )
    fetch_parser.add_argument("session_id", help="Session id to fetch.")
    fetch_parser.add_argument(
        "--source",
        choices=SOURCE_CHOICES,
        default="all",
        help="Read only live sessions or include archived sessions as well.",
    )
    fetch_parser.add_argument(
        "--format",
        choices=("jsonl", "json"),
        default="jsonl",
        help="Output format for the fetched session.",
    )
    fetch_parser.set_defaults(func=run_fetch)

    follow_parser = subparsers.add_parser(
        "follow",
        help="Stream new events for a session id (tail -f style).",
    )
    follow_parser.add_argument("session_id", help="Session id to follow.")
    follow_parser.add_argument(
        "--source",
        choices=SOURCE_CHOICES,
        default="live",
        help="Read only live sessions or include archived sessions as well.",
    )
    follow_parser.add_argument(
        "--format",
        choices=("jsonl", "json"),
        default="jsonl",
        help="Output format for streamed events.",
    )
    follow_parser.add_argument(
        "--since-start",
        action="store_true",
        help="Stream from the beginning of the file instead of only new events.",
    )
    follow_parser.add_argument(
        "--poll-interval",
        type=float,
        default=0.25,
        metavar="SECONDS",
        help="Polling interval for new lines. Default: 0.25 seconds.",
    )
    follow_parser.set_defaults(func=run_follow)
    return parser


def run_list(args: argparse.Namespace) -> int:
    if args.limit < 0:
        print("--limit must be zero or greater.", file=sys.stderr)
        return 2
    if args.max_title < 0:
        print("--max-title must be zero or greater.", file=sys.stderr)
        return 2

    regexes = []
    for raw in args.regex:
        try:
            regexes.append(re.compile(raw, re.IGNORECASE))
        except re.error as exc:
            print(f"Invalid regex pattern {raw!r}: {exc}", file=sys.stderr)
            return 2
    fulltext_regexes = []
    for raw in args.fulltext_regex:
        try:
            fulltext_regexes.append(re.compile(raw, re.IGNORECASE))
        except re.error as exc:
            print(f"Invalid fulltext regex pattern {raw!r}: {exc}", file=sys.stderr)
            return 2
    cwd_regexes = []
    for raw in args.cwd_regex:
        try:
            cwd_regexes.append(re.compile(raw, re.IGNORECASE))
        except re.error as exc:
            print(f"Invalid cwd regex pattern {raw!r}: {exc}", file=sys.stderr)
            return 2
    repo_regexes = []
    for raw in args.repo_regex:
        try:
            repo_regexes.append(re.compile(raw, re.IGNORECASE))
        except re.error as exc:
            print(f"Invalid repo regex pattern {raw!r}: {exc}", file=sys.stderr)
            return 2

    now = datetime.now(timezone.utc)
    status_filter = set(args.status) if args.status else None
    records = collect_sessions(
        source=args.source,
        include_untitled=args.include_untitled,
        query=args.query,
        regexes=regexes,
        cwd_query=args.cwd,
        cwd_regexes=cwd_regexes,
        repo_query=args.repo,
        repo_regexes=repo_regexes,
        fulltext_query=args.fulltext,
        fulltext_regexes=fulltext_regexes,
        now=now,
        running_window_seconds=args.running_window,
        status_filter=status_filter,
        active_within_seconds=args.active_within,
    )

    if args.status:
        allowed = set(args.status)
        records = [record for record in records if record["status"] in allowed]
    if args.active_within is not None:
        records = [
            record
            for record in records
            if (now - record["last_activity_at"]).total_seconds() <= args.active_within
        ]

    sort_records(records, args.sort)
    records = records[: args.limit]

    if args.format == "json":
        print(json.dumps([record_json(record) for record in records], ensure_ascii=False, indent=2))
        return 0

    columns = args.columns or VIEW_COLUMNS[args.view]
    if args.format == "tsv":
        print_tsv(records, columns, args.max_title)
        return 0

    print_table(records, columns, args.max_title)
    return 0


def run_fetch(args: argparse.Namespace) -> int:
    path = find_session_by_id(args.source, args.session_id)
    if path:
        return fetch_session(path, args.format, source=args.source)
    record = index_only_session_by_id(args.source, args.session_id)
    if not record:
        print(f"Session id not found: {args.session_id}", file=sys.stderr)
        return 1
    fallback = emit_recovery_payload(
        "index_only",
        record.get("id") or args.session_id,
        record.get("title") or "",
        record.get("cwd") or "",
        record.get("repo") or "",
        "",
    )
    if args.format == "jsonl":
        print(json.dumps(fallback, ensure_ascii=False))
        return 0
    print(json.dumps([fallback], ensure_ascii=False, indent=2))
    return 0


def run_follow(args: argparse.Namespace) -> int:
    path = find_session_by_id(args.source, args.session_id)
    if not path:
        print(f"Session id not found: {args.session_id}", file=sys.stderr)
        return 1
    return follow_session(
        path=path,
        output_format=args.format,
        since_start=args.since_start,
        poll_interval=args.poll_interval,
    )


def exit_for_broken_stdout_pipe() -> int:
    try:
        devnull_fd = os.open(os.devnull, os.O_WRONLY)
    except OSError:
        return 0
    try:
        os.dup2(devnull_fd, sys.stdout.fileno())
    except OSError:
        pass
    finally:
        os.close(devnull_fd)
    return 0


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    try:
        return args.func(args)
    except BrokenPipeError:
        return exit_for_broken_stdout_pipe()


if __name__ == "__main__":
    raise SystemExit(main())
